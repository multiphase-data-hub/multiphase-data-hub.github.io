{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://multiphase-data-hub.org/schemas/multiphase_info.schema.json",
  "title": "Multiphase Data Hub multiphase_info metadata",
  "type": "object",
  "required": ["schema_version", "dataset_type", "global", "local"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "dataset_type": {
      "const": "multiphase_flow"
    },
    "global": {
      "type": "object",
      "required": [
        "dataset_id",
        "title",
        "version",
        "description",
        "contributors",
        "license",
        "citation",
        "access",
        "physics",
        "method",
        "grid",
        "variables"
      ],
      "properties": {
        "dataset_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "contributors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "affiliation": { "type": "string" },
              "orcid": { "type": "string" },
              "email": { "type": "string" }
            }
          }
        },
        "license": {
          "type": "object",
          "required": ["data"],
          "properties": {
            "data": { "type": "string" },
            "code": { "type": "string" },
            "notes": { "type": "string" }
          }
        },
        "citation": {
          "type": "object"
        },
        "access": {
          "type": "object",
          "required": ["landing_page"],
          "properties": {
            "landing_page": { "type": "string" },
            "download_url": { "type": "string" },
            "repository_url": { "type": "string" },
            "checksums_file": { "type": "string" }
          }
        },
        "physics": {
          "type": "object",
          "required": ["flow_regime", "configuration", "phases", "boundary_conditions", "initial_conditions"],
          "properties": {
            "flow_regime": { "type": "string" },
            "configuration": { "type": "string" },
            "phases": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "role": { "type": "string" },
                  "density": { "type": "object" },
                  "dynamic_viscosity": { "type": "object" }
                }
              }
            },
            "surface_tension": { "type": "object" },
            "gravity": { "type": "object" },
            "dimensionless_numbers": { "type": "object" },
            "boundary_conditions": { "type": "string" },
            "initial_conditions": { "type": "string" }
          }
        },
        "method": {
          "type": "object",
          "required": ["source_type", "interface_representation"],
          "properties": {
            "source_type": {
              "enum": ["simulation", "experiment", "simulation_and_experiment", "derived_ai_dataset"]
            },
            "solver_or_instrument": { "type": "string" },
            "interface_representation": {
              "enum": ["VOF", "level_set", "front_tracking", "phase_field", "SPH", "LBM", "image_mask", "point_cloud", "other"]
            },
            "governing_equations": { "type": "string" },
            "numerical_method": { "type": "object" },
            "experimental_method": { "type": "object" }
          }
        },
        "grid": {
          "type": "object",
          "required": ["spatial_dimension", "grid_type", "shape", "coordinate_order", "cell_location"],
          "properties": {
            "spatial_dimension": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3
            },
            "grid_type": { "type": "string" },
            "shape": {
              "type": "array",
              "items": { "type": "integer", "minimum": 1 }
            },
            "domain_size": { "type": "object" },
            "coordinate_order": { "type": "string" },
            "storage_order": { "type": "string" },
            "cell_location": { "type": "string" },
            "coordinates": { "type": "object" }
          }
        },
        "variables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "standard_name", "required_level", "units", "shape", "dtype", "location"],
            "properties": {
              "name": { "type": "string" },
              "standard_name": { "type": "string" },
              "required_level": { "type": "string" },
              "description": { "type": "string" },
              "units": { "type": "string" },
              "shape": {
                "type": "array",
                "items": {
                  "type": ["string", "integer"]
                }
              },
              "dtype": { "type": "string" },
              "location": { "type": "string" },
              "valid_range": { "type": "array" }
            }
          }
        },
        "ai_metadata": { "type": "object" },
        "known_limitations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "local": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "files"],
        "properties": {
          "id": {
            "type": ["integer", "string"]
          },
          "case_id": { "type": "string" },
          "snapshot_id": {
            "type": ["integer", "string"]
          },
          "time": { "type": "object" },
          "files": {
            "type": "object"
          },
          "case_parameters": {
            "type": "object"
          }
        }
      }
    }
  }
}
